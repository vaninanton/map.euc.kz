{
    "name": "map.euc.kz",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "build:check": "tsc -b && vite build",
        "test": "NODE_OPTIONS=--no-experimental-webstorage vitest run",
        "build:e2e": "VITE_MAPBOX_TOKEN=e2e-mapbox-token VITE_SUPABASE_URL=https://e2e.supabase.co VITE_SUPABASE_PUBLISHABLE_KEY=e2e-publishable-key VITE_TELEGRAM_GEO_TTL_MINUTES=60 VITE_TELEGRAM_TRACK_TAIL_MINUTES=30 VITE_TELEGRAM_MAX_ACCURACY_METERS=100 vite build",
        "pretest:e2e": "npm run build:e2e",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "lint": "eslint .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "preview": "vite preview",
        "generate:pwa-icons": "pwa-asset-generator public/favicon.svg public/icons --icon-only --type png --manifest public/manifest.webmanifest --path-override /icons",
        "generate:pwa-startup": "pwa-asset-generator public/favicon.svg public/icons --splash-only --index index.html --path-override /icons --background \"#0f172a\" --type png",
        "prepare": "husky"
    },
    "dependencies": {
        "@fortawesome/fontawesome-svg-core": "^7.2.0",
        "@fortawesome/free-brands-svg-icons": "^7.2.0",
        "@fortawesome/free-solid-svg-icons": "^7.2.0",
        "@fortawesome/react-fontawesome": "^3.3.1",
        "@supabase/supabase-js": "^2.108.2",
        "mapbox-gl": "^3.25.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-metrika": "^1.0.0",
        "react-router-dom": "^7.18.0",
        "typograf": "^7.7.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@mapbox/point-geometry": "^1.1.0",
        "@playwright/test": "^1.61.1",
        "@tailwindcss/vite": "^4.3.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/geojson": "^7946.0.16",
        "@types/node": "^26.0.0",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.3",
        "eslint": "^10.5.0",
        "eslint-plugin-react-hooks": "7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "globals": "^17.7.0",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "prettier": "^3.8.4",
        "pwa-asset-generator": "^8.1.5",
        "supabase": "^2.107.0",
        "tailwindcss": "^4.3.1",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.62.0",
        "vite": "^8.1.0",
        "vitest": "^4.1.9"
    },
    "allowScripts": {
        "fsevents@2.3.2": true,
        "fsevents@2.3.3": true
    }
}
